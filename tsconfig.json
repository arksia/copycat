{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "~/*": ["./*"]
    },
    "types": ["chrome"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "entrypoints/**/*.ts",
    "entrypoints/**/*.vue",
    "components/**/*.ts",
    "components/**/*.vue",
    "composables/**/*.ts",
    "utils/**/*.ts",
    "types/**/*.ts",
    "tests/**/*.ts",
    ".wxt/wxt.d.ts",
    "vitest.config.ts",
    "wxt.config.ts"
  ]
}
