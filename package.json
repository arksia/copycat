{
  "name": "copycat",
  "type": "module",
  "version": "0.0.1",
  "description": "Your portable project memory for any AI chat — a ghost-text autocomplete extension with your own RAG knowledge base.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "compile": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/chrome": "^0.0.287",
    "@vitejs/plugin-vue": "^6.0.6",
    "@wxt-dev/module-vue": "^1.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.2.1",
    "fake-indexeddb": "^6.2.4",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0",
    "wxt": "^0.20.0"
  }
}
